# ==========================================================
# AI Bill Processing System
# Production .gitignore
# ==========================================================

# ==========================================================
# Python
# ==========================================================

__pycache__/
*.py[cod]
*.pyc
*.pyo
*.pyd
*.so

# Virtual Environment
.venv/
venv/
env/
ENV/

# Python Cache
.pytest_cache/
.mypy_cache/
.ruff_cache/
.pyre/
.tox/
.nox/

.coverage
.coverage.*
htmlcov/

# ==========================================================
# Environment Variables
# ==========================================================

.env
.env.local
.env.development
.env.production
.env.test

# Keep example environment files
!.env.example
!backend/.env.example

# ==========================================================
# Node / React / Vite
# ==========================================================

node_modules/
frontend/node_modules/

dist/
build/
frontend/dist/

.next/
.vite/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ==========================================================
# IDE
# ==========================================================

.vscode/
.idea/

*.iml

# ==========================================================
# macOS / Windows
# ==========================================================

.DS_Store
.AppleDouble
.LSOverride

Thumbs.db
Desktop.ini

# ==========================================================
# Logs
# ==========================================================

logs/
*.log

# ==========================================================
# Database
# ==========================================================

*.sqlite3
*.db

# ==========================================================
# Docker
# ==========================================================

docker-data/
docker-compose.override.yml

# ==========================================================
# Generated Files
# ==========================================================

# Uploads
backend/uploads/*
!backend/uploads/.gitkeep

# Exports
backend/exports/*
!backend/exports/.gitkeep

# Root folders (if used)
uploads/*
!uploads/.gitkeep

exports/*
!exports/.gitkeep

# ==========================================================
# Temporary Files
# ==========================================================

*.tmp
*.temp
*.swp
*.swo
*.bak
*.orig

# ==========================================================
# Git
# ==========================================================

.gitmodules

# ==========================================================
# OS Generated
# ==========================================================

.fseventsd
.Spotlight-V100
.Trashes
