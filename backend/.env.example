##########################################
# AI Bill Processing System
##########################################

APP_NAME=AI Bill Processing System

APP_VERSION=1.0.0

APP_ENV=production

HOST=0.0.0.0

PORT=8000

##########################################
# PostgreSQL
##########################################

DATABASE_URL=postgresql+psycopg://postgres:postgres@db:5432/bill_ai

##########################################
# JWT
##########################################

JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_SECRET

JWT_ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=30

##########################################
# Gemini
##########################################

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

##########################################
# Upload
##########################################

UPLOAD_DIR=uploads

MAX_FILE_SIZE=10485760

ALLOWED_FILE_TYPES=image/jpeg,image/png,application/pdf
